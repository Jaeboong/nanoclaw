DISCORD_BOT_TOKEN=

# Optional: synchronous HTTP API for realtime clients (e.g. RTS game).
# Disabled by default. Set NANOCLAW_HTTP_ENABLED=1 to opt in; an empty
# NANOCLAW_HTTP_TOKEN will refuse to start (no unauthenticated APIs).
NANOCLAW_HTTP_ENABLED=
NANOCLAW_HTTP_TOKEN=
NANOCLAW_HTTP_PORT=4500
